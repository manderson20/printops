[Unit]
Description=PrintOps API (FastAPI/uvicorn)
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
User=__PRINTOPS_USER__
Group=__PRINTOPS_GROUP__
WorkingDirectory=__PRINTOPS_HOME__/apps/api
EnvironmentFile=__PRINTOPS_HOME__/apps/api/.env
ExecStart=__PRINTOPS_HOME__/apps/api/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
