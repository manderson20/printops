[Unit]
Description=PrintOps Web (Next.js)
After=network.target printops-api.service

[Service]
Type=simple
User=__PRINTOPS_USER__
Group=__PRINTOPS_GROUP__
WorkingDirectory=__PRINTOPS_HOME__/apps/web
Environment="PATH=__PRINTOPS_NODE_BIN__:/usr/bin:/bin"
Environment="PORT=3000"
ExecStart=__PRINTOPS_NODE_BIN__/pnpm start
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
