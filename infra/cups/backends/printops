#!/usr/bin/env python3
"""Custom CUPS backend for PrintOps's IPP proxy (Phase 1).

Installed at /usr/lib/cups/backend/printops. CUPS invokes this for every job
sent to a queue whose device-uri is "printops://<printer-uuid>". It logs the
job to the PrintOps API, then delegates actual delivery to CUPS's own built-in
`ipp` backend (pointed at the real printer) rather than re-implementing IPP
Print-Job encoding — see infra/cups/README.md for the full design.

Stdlib only: this runs directly under CUPS (as root, outside any venv), not
through the app's own Python environment.
"""

import json
import os
import re
import shutil
import subprocess
import sys
import urllib.error
import urllib.request

API_BASE = "http://localhost:8000"
REAL_IPP_BACKEND = "/usr/lib/cups/backend/ipp"
ENV_FILE = "/home/itadmin/printops/apps/api/.env"

# Held documents live here until released (app/printers/release.py, invoked
# from printops-api running as `itadmin`) or purged past their expiry
# (app/main.py's background sweep, same process). This script runs as
# root (see module docstring), so the directory is made world read/write —
# no sticky bit, since the release/purge path (itadmin) needs to delete
# files this script (root) created. Acceptable on a single-purpose print
# server where only these two trusted processes ever touch it.
HELD_SPOOL_DIR = "/var/spool/printops-held"


def load_backend_token() -> str:
    with open(ENV_FILE) as f:
        for line in f:
            if line.startswith("PRINTOPS_BACKEND_TOKEN="):
                return line.strip().split("=", 1)[1]
    raise RuntimeError(f"PRINTOPS_BACKEND_TOKEN not found in {ENV_FILE}")


def parse_source_host(job_options: str) -> str | None:
    """CUPS embeds job-originating-host-name=<ip-or-hostname> as one of the
    space-separated key=value tokens in the options string it hands
    backends (alongside finishings=/job-uuid=/etc.) — used by
    app/attribution/resolve.py to try to resolve the actual submitting
    user via MDM device lookup, not just the raw job-originating-user-name
    CUPS already reports via job_user."""
    for token in job_options.split():
        if token.startswith("job-originating-host-name="):
            value = token.removeprefix("job-originating-host-name=")
            return value or None
    return None


JOB_COMPLETION_ATTRIBUTES = [
    "job-media-sheets-completed",
    "sides",
    "output-mode",
    "print-color-mode",
    "media",
]


def get_job_completion_attributes(queue_name: str, job_id: str) -> dict:
    """Reads best-effort post-completion attributes off our own local CUPS
    job record via ipptool, once the real `ipp` backend (below) has already
    finished forwarding — by then cupsd's local job has already been updated
    with whatever the physical printer reported back over the IPP
    back-channel (the same back-channel fd close_fds=False below exists to
    preserve). Feeds Print Insights (app/reports/) — never affects delivery.

    Best-effort per attribute, not just per call: printer/CUPS support
    varies (this is the same caveat page-count capture already had), so any
    attribute the response doesn't include comes back None rather than
    failing the whole job record. Note this is a per-job color mode, not a
    per-page split — see Job.color_mode's docstring (app/models/job.py) for
    why that's what's actually achievable here.
    """
    empty = {"page_count": None, "color_mode": None, "duplex": None, "paper_size": None}
    test_definition = (
        "{\n"
        "    OPERATION Get-Job-Attributes\n"
        "    GROUP operation-attributes-tag\n"
        "    ATTR charset attributes-charset utf-8\n"
        "    ATTR language attributes-natural-language en\n"
        f"    ATTR uri printer-uri ipp://localhost/printers/{queue_name}\n"
        f"    ATTR integer job-id {job_id}\n"
        f"    ATTR keyword requested-attributes {','.join(JOB_COMPLETION_ATTRIBUTES)}\n"
        "}\n"
    )
    try:
        # This CUPS/ipptool build (v2.4.16) doesn't treat "-" as a stdin
        # placeholder for the testfile argument — it requires an actual
        # path, so /dev/stdin is used instead (confirmed via manual
        # ipptool invocation; "-" silently fails with a usage error,
        # which is why page-count capture never actually worked before
        # this fix despite looking correct).
        result = subprocess.run(
            ["ipptool", "-X", f"ipp://localhost/printers/{queue_name}", "/dev/stdin"],
            input=test_definition,
            capture_output=True,
            text=True,
            timeout=10,
        )
    except (OSError, subprocess.TimeoutExpired):
        return empty

    output = result.stdout

    def extract(key: str) -> str | None:
        # ipptool's plist output wraps multi-valued attributes in <array>
        # but emits single-valued ones bare (same "value often comes back
        # bare, not in a list" quirk app/printers/capabilities.py's
        # _as_list() already works around on the pyipp side) — the
        # <array> wrapper is therefore optional here, not guaranteed.
        match = re.search(
            rf"<key>{re.escape(key)}</key>\s*(?:<array>\s*)?<(integer|string)>(.*?)</\1>",
            output,
        )
        return match.group(2) if match else None

    page_count_raw = extract("job-media-sheets-completed")
    sides = extract("sides")
    # Different CUPS/printer combos surface the color decision under
    # different keywords — prefer CUPS's own internal one, fall back to the
    # IPP-standard job attribute.
    color_mode_raw = extract("output-mode") or extract("print-color-mode")

    return {
        "page_count": int(page_count_raw) if page_count_raw and page_count_raw.isdigit() else None,
        "color_mode": (
            None
            if color_mode_raw is None
            else ("monochrome" if "monochrome" in color_mode_raw else "color")
        ),
        "duplex": None if sides is None else sides.startswith("two-sided"),
        "paper_size": extract("media"),
    }


def spool_held_file(job_record_id: str, filename: str | None) -> str:
    """Takes durable custody of the job's document, outside CUPS's own
    temp-file lifecycle — CUPS may clean up `filename` as soon as this
    backend process exits, but a held job's real delivery
    (app/printers/release.py) happens later, in a different process
    entirely. If CUPS handed the document over via stdin instead of a temp
    file (no `filename` arg), it has to be read and saved now — there's no
    second chance to read this process's stdin later."""
    os.makedirs(HELD_SPOOL_DIR, exist_ok=True)
    os.chmod(HELD_SPOOL_DIR, 0o777)
    dest = os.path.join(HELD_SPOOL_DIR, job_record_id)
    if filename:
        shutil.copyfile(filename, dest)
    else:
        with open(dest, "wb") as out:
            shutil.copyfileobj(sys.stdin.buffer, out)
    os.chmod(dest, 0o666)
    return dest


def api_request(token: str, method: str, path: str, body: dict | None = None) -> dict:
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(f"{API_BASE}{path}", data=data, method=method)
    req.add_header("X-Backend-Token", token)
    if data is not None:
        req.add_header("Content-Type", "application/json")
    with urllib.request.urlopen(req, timeout=10) as resp:
        return json.loads(resp.read())


def main() -> int:
    if len(sys.argv) == 1:
        # Discovery mode (e.g. `lpinfo -v`) — queues are created explicitly
        # with a printops:// device-uri, nothing to auto-advertise here.
        return 0

    if len(sys.argv) < 6:
        sys.stderr.write("ERROR: printops backend: wrong number of arguments\n")
        return 1

    job_id, job_user, job_title, job_copies, job_options = sys.argv[1:6]
    filename = sys.argv[6] if len(sys.argv) > 6 else None

    try:
        token = load_backend_token()
    except (OSError, RuntimeError) as exc:
        sys.stderr.write(f"ERROR: printops backend: {exc}\n")
        return 1

    device_uri = os.environ.get("DEVICE_URI", "")
    printer_id = device_uri.removeprefix("printops://").split("/")[0]
    if not printer_id:
        sys.stderr.write(f"ERROR: printops backend: bad DEVICE_URI {device_uri!r}\n")
        return 1

    try:
        printer = api_request(token, "GET", f"/api/v1/internal/printers/{printer_id}/connection")
    except (urllib.error.URLError, urllib.error.HTTPError) as exc:
        sys.stderr.write(f"ERROR: printops backend: printer lookup failed: {exc}\n")
        return 1

    file_size = None
    if filename:
        try:
            file_size = os.path.getsize(filename)
        except OSError:
            file_size = None

    copy_count = int(job_copies) if job_copies.isdigit() else None

    try:
        job = api_request(
            token,
            "POST",
            "/api/v1/jobs",
            {
                "printer_id": printer_id,
                "cups_job_id": int(job_id),
                "submitted_by": job_user,
                "file_size_bytes": file_size,
                "source_host": parse_source_host(job_options),
                "document_name": job_title or None,
                "copy_count": copy_count,
            },
        )
    except (urllib.error.URLError, urllib.error.HTTPError) as exc:
        sys.stderr.write(f"ERROR: printops backend: could not log job: {exc}\n")
        return 1

    job_record_id = job["id"]

    # Whether to hold instead of forward, and why, is decided server-side in
    # create_job (app/routers/jobs.py:create_job ->
    # app/quotas/service.py:resolve_hold_reason) — covers both a
    # release_required printer ("pin_release") and a user over their page
    # quota ("quota"). This script just reacts to whichever came back on the
    # job it already created above, rather than deciding anything itself.
    if job.get("hold_reason"):
        try:
            held_path = spool_held_file(job_record_id, filename)
        except OSError as exc:
            sys.stderr.write(f"ERROR: printops backend: could not spool held document: {exc}\n")
            return 1
        try:
            held_file_size = os.path.getsize(held_path)
        except OSError:
            held_file_size = file_size
        try:
            api_request(
                token,
                "PATCH",
                f"/api/v1/jobs/{job_record_id}",
                {
                    "status": "held",
                    "held_file_path": held_path,
                    "held_job_options": job_options,
                    "file_size_bytes": held_file_size,
                },
            )
        except (urllib.error.URLError, urllib.error.HTTPError) as exc:
            # Unlike the best-effort PATCHes below: without this recorded,
            # the job can never be found/released, so a spooled-but-unmarked
            # file is a real (if rare) stuck state — surface it as a failure
            # rather than silently succeeding.
            sys.stderr.write(f"ERROR: printops backend: could not mark job held: {exc}\n")
            return 1
        return 0

    scheme = "ipps" if printer["use_tls"] else "ipp"
    real_uri = (
        f"{scheme}://{printer['ip_address']}:{printer['port']}"
        f"{printer.get('ipp_path') or '/ipp/print'}"
    )

    real_argv = [REAL_IPP_BACKEND, job_id, job_user, job_title, job_copies, job_options]
    if filename:
        real_argv.append(filename)

    child_env = dict(os.environ)
    child_env["DEVICE_URI"] = real_uri

    # close_fds=False: cupsd hands this script fds beyond 0/1/2 — notably a
    # back-channel (job status/auth) fd the real `ipp` backend polls on.
    # subprocess's default close_fds=True closes those before exec, so the
    # real backend was polling a dead fd and spinning forever (EBADF loop)
    # instead of ever opening the connection to the printer.
    if filename:
        exit_code = subprocess.run(real_argv, env=child_env, close_fds=False).returncode
    else:
        # No filename means CUPS handed the document over via stdin instead
        # of a temp file — proxy it through to the real backend ourselves
        # (rather than the simpler stdin=sys.stdin fd handoff) so we can
        # count bytes as they stream past, the only way to learn this job's
        # size in this path. Same blocking/backpressure semantics as a
        # shell pipe: our writes just block until the child drains, no
        # deadlock risk since we never read the child's own stdout/stderr.
        proc = subprocess.Popen(real_argv, env=child_env, stdin=subprocess.PIPE, close_fds=False)
        file_size = 0
        try:
            while True:
                chunk = sys.stdin.buffer.read(262144)
                if not chunk:
                    break
                proc.stdin.write(chunk)
                file_size += len(chunk)
        except OSError:
            pass  # child exited early (e.g. auth failure) — its own exit code reports the failure
        finally:
            proc.stdin.close()
        exit_code = proc.wait()

    completion_attrs = {"page_count": None, "color_mode": None, "duplex": None, "paper_size": None}
    if exit_code == 0:
        queue_name = os.environ.get("PRINTER") or f"printops-{printer_id}"
        completion_attrs = get_job_completion_attributes(queue_name, job_id)

    try:
        api_request(
            token,
            "PATCH",
            f"/api/v1/jobs/{job_record_id}",
            {
                "status": "forwarded" if exit_code == 0 else "failed",
                "error_message": None if exit_code == 0 else f"ipp backend exited {exit_code}",
                "file_size_bytes": file_size,
                **completion_attrs,
            },
        )
    except (urllib.error.URLError, urllib.error.HTTPError):
        pass  # best-effort status report; don't fail the print over a logging hiccup

    return exit_code


if __name__ == "__main__":
    sys.exit(main())
