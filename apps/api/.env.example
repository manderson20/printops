# Prefix matches Settings(env_prefix="PRINTOPS_") in app/core/config.py
PRINTOPS_ENVIRONMENT=development
PRINTOPS_CORS_ORIGINS=["http://localhost:3000"]

PRINTOPS_JWT_SECRET=change-me-generate-a-long-random-secret
PRINTOPS_JWT_ALGORITHM=HS256
PRINTOPS_JWT_EXPIRES_MINUTES=60

# Stubbed single dev user for the auth placeholder (see app/routers/auth.py)
PRINTOPS_DEV_USERNAME=admin
PRINTOPS_DEV_PASSWORD=change-me

# Needs the +asyncpg driver suffix — app/db.py hands this straight to
# SQLAlchemy's async engine, which picks its driver from the URL scheme.
PRINTOPS_DATABASE_URL=postgresql+asyncpg://printops:change-me@localhost:5432/printops

# Shared secret the CUPS backend script (infra/cups/backends/printops) uses to
# call the jobs API — not a user credential, generate with e.g. `openssl rand -hex 32`
PRINTOPS_BACKEND_TOKEN=change-me-generate-a-long-random-token

# Fernet key for encrypting third-party integration credentials at rest
# (Google Workspace/SSO, Mosyle, etc. — see app/core/crypto.py). Generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PRINTOPS_ENCRYPTION_KEY=change-me-generate-a-fernet-key

# Reserved for future use — not connected to anything yet in this scaffold
PRINTOPS_REDIS_URL=redis://localhost:6379/0
