# Prefix matches Settings(env_prefix="PRINTOPS_") in app/core/config.py
PRINTOPS_ENVIRONMENT=development
PRINTOPS_CORS_ORIGINS=["http://localhost:3000"]

PRINTOPS_JWT_SECRET=change-me-in-any-real-deployment
PRINTOPS_JWT_ALGORITHM=HS256
PRINTOPS_JWT_EXPIRES_MINUTES=60

# Stubbed single dev user for the auth placeholder (see app/routers/auth.py)
PRINTOPS_DEV_USERNAME=admin
PRINTOPS_DEV_PASSWORD=changeme

PRINTOPS_DATABASE_URL=postgresql+asyncpg://printops:printops@localhost:5432/printops

# Shared secret the CUPS backend script (infra/cups/backends/printops) uses to
# call the jobs API — not a user credential, generate with e.g. `openssl rand -hex 32`
PRINTOPS_BACKEND_TOKEN=change-me-in-any-real-deployment

# Reserved for future use — not connected to anything yet in this scaffold
PRINTOPS_REDIS_URL=redis://localhost:6379/0
